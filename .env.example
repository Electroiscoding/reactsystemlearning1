# === LLM Configuration ===
# Your API key (OpenAI, Groq, OpenRouter, etc.)
API_KEY=sk-your-key-here

# Base URL for the API (change for non-OpenAI providers)
# OpenAI:      https://api.openai.com/v1
# Groq:        https://api.groq.com/openai/v1
# OpenRouter:   https://openrouter.ai/api/v1
# Ollama:      http://localhost:11434/v1
BASE_URL=https://api.openai.com/v1

# Model to use
MODEL=gpt-4o

# === Agent Configuration ===
# Max ReAct loop iterations before stopping
MAX_STEPS=30

# Max characters of tool output to feed back to the LLM
MAX_OUTPUT_LENGTH=10000

# Working directory for the agent (defaults to cwd)
# WORKDIR=/path/to/your/project
